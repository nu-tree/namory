{
  "name": "namory-monorepo",
  "version": "0.0.0",
  "description": "제2의 뇌 시스템 모노레포 — namory(저장/회상) + 향후 agent 등",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter namory-mcp dev",
    "dev:navis": "pnpm --filter navis dev",
    "namory": "pnpm --filter namory-mcp",
    "navis": "pnpm --filter navis"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.0.8"
}
