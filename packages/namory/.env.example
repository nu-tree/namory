# MCP 엔드포인트 보호용 단일 시크릿 (Supabase Auth와 무관 — 공개 HTTP라 필요)
# 강한 랜덤 권장: `openssl rand -hex 32`
# 사용: 헤더 `Authorization: Bearer <값>` 또는 URL `.../mcp?token=<값>`
# (Claude 커스텀 커넥터 UI엔 토큰 입력란이 없어 후자 사용)
NAMORY_TOKEN=

# Supabase Postgres 연결 문자열 (Drizzle / postgres-js)
DATABASE_URL=

# Voyage AI
VOYAGE_API_KEY=

PORT=3000

# 선택: recall 시간 가중치 — 신규 기억일수록 점수 부스트.
# 공식: score = similarity × (1 + BOOST × exp(-age_days / TAU))
# 0이면 시간 무시(순수 코사인), 클수록 최신 편향. 기본 0.3 / 30일.
# RECALL_FRESHNESS_BOOST=0.3
# RECALL_FRESHNESS_TAU_DAYS=30
