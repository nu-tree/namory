# 디스코드 봇 토큰 (Discord Developer Portal → Bot → Reset Token)
# 봇 설정에서 MESSAGE CONTENT INTENT 를 반드시 켜야 메시지 내용을 읽을 수 있음.
DISCORD_TOKEN=

# 봇에 명령할 수 있는 디스코드 유저 ID (쉼표로 여러 명). 이 목록 외엔 무시.
# 본인 ID 얻기: 디스코드 설정 → 고급 → 개발자 모드 ON → 프로필 우클릭 → ID 복사
ALLOWED_USER_IDS=

# Claude Code 구독 OAuth 토큰. 로컬에서 `claude setup-token` 으로 발급.
# (일반 ANTHROPIC_API_KEY 아님 — 구독 한도 안에서 쓰는 토큰)
CLAUDE_CODE_OAUTH_TOKEN=

# 선택: 모델 (기본 claude-sonnet-4-6)
# AGENT_MODEL=claude-sonnet-4-6

# 선택: 봇 시스템 프롬프트 덮어쓰기
# AGENT_SYSTEM_PROMPT=

# 헬스체크 포트 (Railway가 자동 주입)
PORT=3000
