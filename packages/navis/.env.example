# 디스코드 봇 토큰 (Discord Developer Portal → Bot → Reset Token)
# 봇 설정에서 MESSAGE CONTENT INTENT 를 반드시 켜야 메시지 내용을 읽을 수 있음.
DISCORD_TOKEN=

# 봇에 명령할 수 있는 디스코드 유저 ID (쉼표로 여러 명). 이 목록 외엔 무시.
# 본인 ID 얻기: 디스코드 설정 → 고급 → 개발자 모드 ON → 프로필 우클릭 → ID 복사
ALLOWED_USER_IDS=

# Claude Code 구독 OAuth 토큰. 로컬에서 `claude setup-token` 으로 발급.
# (일반 ANTHROPIC_API_KEY 아님 — 구독 한도 안에서 쓰는 토큰)
CLAUDE_CODE_OAUTH_TOKEN=

# namory MCP 서버 주소. 로컬 테스트: http://localhost:3000/mcp
# Railway 내부망: http://namory.railway.internal:<namory포트>/mcp
NAMORY_MCP_URL=http://localhost:3000/mcp

# namory 엔드포인트 토큰 (namory 서비스의 NAMORY_TOKEN과 같은 값)
NAMORY_TOKEN=

# 선택: 노션 연동. 토큰이 있을 때만 navis가 self-host MCP(@notionhq/notion-mcp-server)를
# stdio로 띄운다. OAuth 안 탐 — notion.so/my-integrations 의 내부 통합 토큰(ntn_...)을 넣고,
# 봇이 쓸 페이지/DB를 그 통합에 공유(connect)하면 됨. URL 불필요.
# NOTION_TOKEN=

# 선택: 구글(캘린더/Gmail) 커넥터 연동. URL+토큰 둘 다 있을 때만 붙는다.
# GOOGLE_MCP_URL=https://gmailmcp.googleapis.com/mcp/v1
# GOOGLE_TOKEN=

# 선택: 모델 (기본 claude-sonnet-4-6)
# AGENT_MODEL=claude-sonnet-4-6

# 선택: 대화 맥락 유지 한도(토큰). 한 대화 컨텍스트가 이걸 넘으면 다음 메시지부터
# 새 세션으로 리셋하고 사용자에게 알림(비용·지연 폭주 방지). 기본 100000.
# /reset 으로 수동 초기화도 가능.
# CONTEXT_TOKEN_LIMIT=100000

# 헬스체크 포트 (Railway가 자동 주입)
PORT=3000

# 봇 성격·행동 지침 (필수). 코드에 두지 않고 여기/Railway 변수로만 주입 — 레포 공개 대비.
# 멀티라인 + 내부 따옴표(' ")가 섞이므로 백틱(`)으로 감싼다(Node --env-file이 백틱 지원).
# Railway에선 변수 값에 멀티라인 그대로 붙여넣으면 됨(백틱 불필요).
# SYSTEM_PROMPT=`당신은 사용자 전용 비서 '나비스(navis)'이며 ...
# ... 여러 줄 ...`
